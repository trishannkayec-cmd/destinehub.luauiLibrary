        -- ============================================================
        function tabObj:CreateKeybind(opts)
            -- simple implementation stub
        end

        if not Window._activeTab then
            setActiveTab(tabObj)
        end

        table.insert(Window._tabs, tabObj)
        return tabObj
    end

    return Window
end

return Library
