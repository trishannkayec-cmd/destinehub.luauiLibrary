function Library:CreateWindow(opts)
    opts = opts or {}
    local title    = opts.Title  or "DestineLib"
    local size     = opts.Size   or UDim2.fromOffset(530, 330)
    local loader   = opts.Loader ~= false

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "DestineLib_" .. title
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    ScreenGui.ResetOnSpawn = false
    pcall(function() ScreenGui.Parent = CoreGui end)
    if not ScreenGui.Parent then ScreenGui.Parent = LocalPlayer.PlayerGui end

    -- Main Window Frame
    local MainFrame = create("Frame", {
        Name = "MainFrame",
        BackgroundColor3 = Theme.Background,
        Position = UDim2.new(0.5, 0, 0.5, 0),
        AnchorPoint = Vector2.new(0.5, 0.5),
        Size = UDim2.new(0, 0, 0, 0),
        ClipsDescendants = true,
        Parent = ScreenGui
    })
    corner(10, MainFrame)
    stroke(Theme.Border, 1, MainFrame)

    -- Title Bar
    local TitleBar = create("Frame", {
        Name = "TitleBar",
        BackgroundColor3 = Theme.TitleBar,
        Size = UDim2.new(1, 0, 0, 38),
        Parent = MainFrame
    })
    corner(10, TitleBar)
    -- Cover bottom corners of titlebar
    create("Frame", {
        BackgroundColor3 = Theme.TitleBar,
        Position = UDim2.new(0, 0, 0.5, 0),
        Size = UDim2.new(1, 0, 0.5, 0),
        BorderSizePixel = 0,
        Parent = TitleBar
    })

    local TitleLabel = create("TextLabel", {
        Text = title,
        Font = Enum.Font.GothamBold,
        TextSize = 14,
        TextColor3 = Theme.Text,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 14, 0, 0),
        Size = UDim2.new(1, -80, 1, 0),
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = TitleBar
    })

    -- Close Button
    local CloseBtn = create("TextButton", {
        Text = "✕",
        Font = Enum.Font.GothamBold,
        TextSize = 14,
        TextColor3 = Theme.TextMuted,
        BackgroundColor3 = Color3.fromRGB(200, 60, 60),
        BackgroundTransparency = 1,
        Position = UDim2.new(1, -32, 0.5, -10),
        Size = UDim2.new(0, 20, 0, 20),
        Parent = TitleBar
    })
    corner(4, CloseBtn)
    CloseBtn.MouseEnter:Connect(function()
        tween(CloseBtn, {BackgroundTransparency = 0, TextColor3 = Color3.new(1,1,1)}, 0.15)
    end)
    CloseBtn.MouseLeave:Connect(function()
        tween(CloseBtn, {BackgroundTransparency = 1, TextColor3 = Theme.TextMuted}, 0.15)
    end)
    CloseBtn.MouseButton1Click:Connect(function()
        tween(MainFrame, {Size = UDim2.new(0, 0, 0, 0)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        task.delay(0.35, function() ScreenGui:Destroy() end)
    end)

    -- Minimize Button
    local MinBtn = create("TextButton", {
        Text = "–",
        Font = Enum.Font.GothamBold,
        TextSize = 16,
        TextColor3 = Theme.TextMuted,
        BackgroundColor3 = Theme.SurfaceAlt,
        BackgroundTransparency = 1,
        Position = UDim2.new(1, -56, 0.5, -10),
        Size = UDim2.new(0, 20, 0, 20),
        Parent = TitleBar
    })
    corner(4, MinBtn)
    local minimized = false
    local fullSize = size
    MinBtn.MouseEnter:Connect(function()
        tween(MinBtn, {BackgroundTransparency = 0, TextColor3 = Theme.Text}, 0.15)
    end)
    MinBtn.MouseLeave:Connect(function()
        tween(MinBtn, {BackgroundTransparency = 1, TextColor3 = Theme.TextMuted}, 0.15)
    end)
    MinBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        if minimized then
            tween(MainFrame, {Size = UDim2.new(0, fullSize.X.Offset, 0, 38)}, 0.3, Enum.EasingStyle.Quad)
        else
            tween(MainFrame, {Size = fullSize}, 0.3, Enum.EasingStyle.Quad)
        end
    end)

    makeDraggable(MainFrame, TitleBar)

    -- Tab Bar
    local TabBar = create("Frame", {
        Name = "TabBar",
        BackgroundColor3 = Theme.TitleBar,
        Position = UDim2.new(0, 0, 0, 38),
        Size = UDim2.new(0, 110, 1, -38),
        Parent = MainFrame
    })
    local tabLayout = listLayout(TabBar, 2, Enum.FillDirection.Vertical)
    tabLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    padding(8, 8, 6, 6, TabBar)

    -- Content Area
    local ContentArea = create("Frame", {
        Name = "ContentArea",
        BackgroundColor3 = Theme.Background,
        Position = UDim2.new(0, 110, 0, 38),
        Size = UDim2.new(1, -110, 1, -38),
        ClipsDescendants = true,
        Parent = MainFrame
    })

    -- Separator line between sidebar and content
    create("Frame", {
        BackgroundColor3 = Theme.Border,
        Position = UDim2.new(0, 109, 0, 38),
        Size = UDim2.new(0, 1, 1, -38),
        BorderSizePixel = 0,
        Parent = MainFrame
    })

    -- Loader animation
    if loader then
        local Loader = create("Frame", {
            BackgroundColor3 = Theme.Background,
            Size = UDim2.new(1, 0, 1, 0),
            ZIndex = 10,
            Parent = MainFrame
        })
        corner(10, Loader)
        local ring = create("Frame", {
            BackgroundColor3 = Color3.fromRGB(0,0,0),
            BackgroundTransparency = 1,
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.new(0.5, 0, 0.45, 0),
            Size = UDim2.new(0, 40, 0, 40),
            Parent = Loader
        })
        create("UICorner", { CornerRadius = UDim.new(1, 0), Parent = ring })
        stroke(Theme.Accent, 3, ring)
        create("TextLabel", {
            Text = "Loading " .. title .. "...",
            Font = Enum.Font.Gotham,
            TextSize = 12,
            TextColor3 = Theme.TextMuted,
            BackgroundTransparency = 1,
            AnchorPoint = Vector2.new(0.5, 0),
            Position = UDim2.new(0.5, 0, 0.6, 0),
            Size = UDim2.new(0.8, 0, 0, 20),
            Parent = Loader
        })
        local angle = 0
        local conn = RunService.RenderStepped:Connect(function(dt)
            angle = angle + dt * 180
            ring.Rotation = angle
        end)
        task.delay(1.5, function()
            conn:Disconnect()
            tween(Loader, {BackgroundTransparency = 1}, 0.4)
            for _, d in ipairs(Loader:GetDescendants()) do
                if d:IsA("TextLabel") then tween(d, {TextTransparency = 1}, 0.3) end
                if d:IsA("UIStroke") then tween(d, {Transparency = 1}, 0.3) end
            end
            task.delay(0.45, function() Loader:Destroy() end)
        end)
    end

    -- Animate open
    tween(MainFrame, {Size = size}, 0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

    -- ============================================================
    -- WINDOW OBJECT
    -- ============================================================
    local Window = { _tabs = {}, _activeTab = nil }

    local function setActiveTab(tabObj)
        if Window._activeTab == tabObj then return end
        if Window._activeTab then
            Window._activeTab.Page.Visible = false
            tween(Window._activeTab.Btn, {
                BackgroundColor3 = Theme.TabInactive,
                TextColor3 = Theme.TextMuted
            }, 0.15)
        end
        Window._activeTab = tabObj
        tabObj.Page.Visible = true
        tween(tabObj.Btn, {
            BackgroundColor3 = Theme.Accent,
            TextColor3 = Theme.Text
        }, 0.15)
    end

    function Window:CreateTab(name, icon)
        local Btn = create("TextButton", {
            Text = (icon and icon .. "  " or "") .. name,
            Font = Enum.Font.Gotham,
            TextSize = 12,
            TextColor3 = Theme.TextMuted,
            BackgroundColor3 = Theme.TabInactive,
            Size = UDim2.new(1, 0, 0, 32),
            TextXAlignment = Enum.TextXAlignment.Left,
            Parent = TabBar
        })
        corner(6, Btn)
        padding(0, 0, 10, 8, Btn)

        Btn.MouseEnter:Connect(function()
            if Window._activeTab and Window._activeTab.Btn == Btn then return end
            tween(Btn, {BackgroundColor3 = Theme.SurfaceAlt, TextColor3 = Theme.Text}, 0.12)
        end)
        Btn.MouseLeave:Connect(function()
            if Window._activeTab and Window._activeTab.Btn == Btn then return end
            tween(Btn, {BackgroundColor3 = Theme.TabInactive, TextColor3 = Theme.TextMuted}, 0.12)
        end)

        -- Scrollable page
        local Page = create("ScrollingFrame", {
            Name = name .. "Page",
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 0, 0, 0),
            Size = UDim2.new(1, 0, 1, 0),
            CanvasSize = UDim2.new(0, 0, 0, 0),
            ScrollBarThickness = 3,
            ScrollBarImageColor3 = Theme.ScrollBar,
            Visible = false,
            BorderSizePixel = 0,
            Parent = ContentArea
        })
        padding(8, 8, 8, 8, Page)

        -- Two-column layout holder
        local ColHolder = create("Frame", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            Parent = Page
        })
        local colLayout = listLayout(ColHolder, 8, Enum.FillDirection.Horizontal)
        colLayout.VerticalAlignment = Enum.VerticalAlignment.Top

        -- Auto canvas size
        local pageLayout = Instance.new("UIListLayout")
        pageLayout.SortOrder = Enum.SortOrder.LayoutOrder
        pageLayout.Padding = UDim.new(0, 0)
        pageLayout.Parent = Page
        pageLayout.Changed:Connect(function()
            Page.CanvasSize = UDim2.new(0, 0, 0, pageLayout.AbsoluteContentSize.Y + 20)
        end)
        ColHolder.LayoutOrder = 1

        Btn.MouseButton1Click:Connect(function()
            setActiveTab(tabObj)
        end)

        local tabObj = {
            Btn = Btn,
            Page = Page,
            ColHolder = ColHolder,
            _leftCol = nil,
            _rightCol = nil,
        }

        -- Ensure columns exist
        local function ensureColumns()
            if tabObj._leftCol then return end
            tabObj._leftCol = create("Frame", {
                BackgroundTransparency = 1,
                Size = UDim2.new(0.5, -4, 0, 0),
                AutomaticSize = Enum.AutomaticSize.Y,
                Parent = ColHolder
            })
            listLayout(tabObj._leftCol, 6, Enum.FillDirection.Vertical)

            tabObj._rightCol = create("Frame", {
                BackgroundTransparency = 1,
                Size = UDim2.new(0.5, -4, 0, 0),
                AutomaticSize = Enum.AutomaticSize.Y,
                Parent = ColHolder
            })
            listLayout(tabObj._rightCol, 6, Enum.FillDirection.Vertical)
        end

        -- ============================================================
        -- SECTION
        -- ============================================================
        function tabObj:CreateSection(name, opts)
            opts = opts or {}
            local sideStr = opts.Side or "full"
            local sectionIcon = opts.Icon or ""
            local defaultOpen = opts.DefaultOpen ~= false

            local targetParent
            if sideStr == "left" then
                ensureColumns()
                targetParent = tabObj._leftCol
            elseif sideStr == "right" then
                ensureColumns()
                targetParent = tabObj._rightCol
            else
                targetParent = Page
            end

            local SectionFrame = create("Frame", {
                BackgroundColor3 = Theme.Surface,
                Size = UDim2.new(1, 0, 0, 0),
                AutomaticSize = Enum.AutomaticSize.Y,
                Parent = targetParent
            })
            corner(8, SectionFrame)
            stroke(Theme.Border, 1, SectionFrame)

            -- Section header
            local Header = create("TextButton", {
                Text = "",
                BackgroundColor3 = Theme.SurfaceAlt,
                Size = UDim2.new(1, 0, 0, 30),
                Parent = SectionFrame
            })
            corner(8, Header)
            -- cover bottom corners
            create("Frame", {
                BackgroundColor3 = Theme.SurfaceAlt,
                Position = UDim2.new(0, 0, 0.5, 0),
                Size = UDim2.new(1, 0, 0.5, 0),
                BorderSizePixel = 0,
                Parent = Header
            })
            create("TextLabel", {
                Text = sectionIcon .. (sectionIcon ~= "" and "  " or "") .. name,
                Font = Enum.Font.GothamSemibold,
                TextSize = 12,
                TextColor3 = Theme.Text,
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 10, 0, 0),
                Size = UDim2.new(1, -30, 1, 0),
                TextXAlignment = Enum.TextXAlignment.Left,
                Parent = Header
            })
            local Arrow = create("TextLabel", {
                Text = defaultOpen and "▾" or "▸",
                Font = Enum.Font.GothamBold,
                TextSize = 13,
                TextColor3 = Theme.TextMuted,
                BackgroundTransparency = 1,
                Position = UDim2.new(1, -24, 0, 0),
                Size = UDim2.new(0, 20, 1, 0),
                Parent = Header
            })

            local ItemContainer = create("Frame", {
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 0),
                AutomaticSize = Enum.AutomaticSize.Y,
                ClipsDescendants = true,
                Visible = defaultOpen,
                Parent = SectionFrame
            })
            padding(4, 4, 8, 8, ItemContainer)
            listLayout(ItemContainer, 5, Enum.FillDirection.Vertical)

            local isOpen = defaultOpen
            Header.MouseButton1Click:Connect(function()
                isOpen = not isOpen
                ItemContainer.Visible = isOpen
                Arrow.Text = isOpen and "▾" or "▸"
            end)

            local Section = {}

            -- --------------------------------------------------------
            -- LABEL
            -- --------------------------------------------------------
            function Section:CreateLabel(opts)
                opts = opts or {}
                local lbl = create("TextLabel", {
                    Text = (opts.Icon and opts.Icon .. "  " or "") .. (opts.Text or ""),
                    Font = Enum.Font.Gotham,
                    TextSize = 12,
                    TextColor3 = opts.Color or Theme.TextMuted,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 22),
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = ItemContainer
                })
                return lbl
            end

            -- --------------------------------------------------------
            -- PARAGRAPH
            -- --------------------------------------------------------
            function Section:CreateParagraph(opts)
                opts = opts or {}
                local holder = create("Frame", {
                    BackgroundColor3 = Theme.SurfaceAlt,
                    Size = UDim2.new(1, 0, 0, 0),
                    AutomaticSize = Enum.AutomaticSize.Y,
                    Parent = ItemContainer
                })
                corner(6, holder)
                padding(6, 6, 8, 8, holder)
                listLayout(holder, 4)

                if opts.Image and opts.Image ~= "" then
                    local img = create("ImageLabel", {
                        Image = opts.Image,
                        BackgroundColor3 = Theme.Border,
                        Size = UDim2.new(0, 36, 0, 36),
                        Parent = holder
                    })
                    corner(18, img)
                end
                create("TextLabel", {
                    Text = opts.Title or "",
                    Font = Enum.Font.GothamBold,
                    TextSize = 12,
                    TextColor3 = Theme.Text,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 18),
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = holder
                })
                create("TextLabel", {
                    Text = opts.Content or "",
                    Font = Enum.Font.Gotham,
                    TextSize = 11,
                    TextColor3 = Theme.TextMuted,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 0),
                    AutomaticSize = Enum.AutomaticSize.Y,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextWrapped = true,
                    Parent = holder
                })
            end

            -- --------------------------------------------------------
            -- TOGGLE
            -- --------------------------------------------------------
            function Section:CreateToggle(opts)
                opts = opts or {}
                local state = opts.Default or false
                local cb = opts.Callback or function() end

                local row = create("Frame", {
                    BackgroundColor3 = Theme.SurfaceAlt,
                    Size = UDim2.new(1, 0, 0, 32),
                    Parent = ItemContainer
                })
                corner(6, row)

                create("TextLabel", {
                    Text = (opts.Icon and opts.Icon .. "  " or "") .. (opts.Name or "Toggle"),
                    Font = Enum.Font.Gotham,
                    TextSize = 12,
                    TextColor3 = Theme.Text,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 10, 0, 0),
                    Size = UDim2.new(1, -55, 1, 0),
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = row
                })

                local Track = create("Frame", {
                    BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff,
                    Position = UDim2.new(1, -42, 0.5, -9),
                    Size = UDim2.new(0, 36, 0, 18),
                    Parent = row
                })
                corner(9, Track)
                local Knob = create("Frame", {
                    BackgroundColor3 = Color3.new(1, 1, 1),
                    Position = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7),
                    Size = UDim2.new(0, 14, 0, 14),
                    Parent = Track
                })
                corner(7, Knob)

                local function updateVisual()
                    tween(Track, {BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff}, 0.18)
                    tween(Knob, {Position = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)}, 0.18)
                end

                local Btn = create("TextButton", {
                    Text = "",
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Parent = row
                })
                Btn.MouseButton1Click:Connect(function()
                    state = not state
                    updateVisual()
                    cb(state)
                end)

                local Toggle = {}
                function Toggle:Set(val)
                    state = val
                    updateVisual()
                    cb(state)
                end
                return Toggle
            end

            -- --------------------------------------------------------
            -- SLIDER
            -- --------------------------------------------------------
            function Section:CreateSlider(opts)
                opts = opts or {}
                local min = opts.Min or 0
                local max = opts.Max or 100
                local val = math.clamp(opts.Default or min, min, max)
                local cb = opts.Callback or function() end

                local row = create("Frame", {
                    BackgroundColor3 = Theme.SurfaceAlt,
                    Size = UDim2.new(1, 0, 0, 44),
                    Parent = ItemContainer
                })
                corner(6, row)

                create("TextLabel", {
                    Text = (opts.Icon and opts.Icon .. "  " or "") .. (opts.Name or "Slider"),
                    Font = Enum.Font.Gotham,
                    TextSize = 12,
                    TextColor3 = Theme.Text,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 10, 0, 4),
                    Size = UDim2.new(0.7, 0, 0, 18),
                    TextXAlignment = Enum.TextXAlignment.Left,
                    Parent = row
                })

                local ValLabel = create("TextLabel", {
                    Text = tostring(val),
                    Font = Enum.Font.GothamBold,
                    TextSize = 12,
                    TextColor3 = Theme.Accent,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0.7, 0, 0, 4),
                    Size = UDim2.new(0.3, -10, 0, 18),
                    TextXAlignment = Enum.TextXAlignment.Right,
                    Parent = row
                })

                local Track = create("Frame", {
                    BackgroundColor3 = Theme.SliderBg,
                    Position = UDim2.new(0, 10, 0, 30),
                    Size = UDim2.new(1, -20, 0, 6),
                    Parent = row
                })
                corner(3, Track)

                local Fill = create("Frame", {
                    BackgroundColor3 = Theme.SliderFill,
                    Size = UDim2.new((val - min) / (max - min), 0, 1, 0),
                    Parent = Track
                })
                corner(3, Fill)

                local Knob = create("Frame", {
                    BackgroundColor3 = Color3.new(1,1,1),
                    AnchorPoint = Vector2.new(0.5, 0.5),
                    Position = UDim2.new((val - min)/(max - min), 0, 0.5, 0),
                    Size = UDim2.new(0, 12, 0, 12),
                    ZIndex = 2,
                    Parent = Track
                })
                corner(6, Knob)
                stroke(Theme.SliderFill, 2, Knob)

                local sliding = false
                local Btn = create("TextButton", {
                    Text = "",
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 20),
                    Position = UDim2.new(0, 0, 0, 20),
                    Parent = row
                })
                Btn.MouseButton1Down:Connect(function()
                    sliding = true
                end)
                UserInputService.InputEnded:Connect(function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                        sliding = false
                    end
                end)
                UserInputService.InputChanged:Connect(function(inp)
                    if sliding and inp.UserInputType == Enum.UserInputType.MouseMovement then
                        local abs = Track.AbsolutePosition
                        local sz  = Track.AbsoluteSize
                        local pct = math.clamp((inp.Position.X - abs.X) / sz.X, 0, 1)
                        val = math.round(min + (max - min) * pct)
                        ValLabel.Text = tostring(val)
                        tween(Fill, {Size = UDim2.new(pct, 0, 1, 0)}, 0.05)
                        tween(Knob, {Position = UDim2.new(pct, 0, 0.5, 0)}, 0.05)
                        cb(val)
                    end
                end)

                local Slider = {}
                function Slider:Set(v)
                    val = math.clamp(v, min, max)
                    local pct = (val - min) / (max - min)
                    ValLabel.Text = tostring(val)
                    tween(Fill, {Size = UDim2.new(pct, 0, 1, 0)}, 0.1)
                    tween(Knob, {Position = UDim2.new(pct, 0, 0.5, 0)}, 0.1)
                    cb(val)
                end
                return Slider
            end

            -- --------------------------------------------------------
            -- BUTTON
            -- --------------------------------------------------------
            function Section:CreateButton(opts)
                opts = opts or {}
                local cb = opts.Callback or function() end

                local Btn = create("TextButton", {
                    Text = (opts.Icon and opts.Icon .. "  " or "") .. (opts.Name or "Button"),
