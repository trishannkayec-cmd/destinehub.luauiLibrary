                end)
                Btn.MouseLeave:Connect(function()
                    tween(Btn, {BackgroundColor3 = Theme.Accent}, 0.12)
                end)
                Btn.MouseButton1Down:Connect(function()
                    tween(Btn, {BackgroundColor3 = Theme.AccentDim}, 0.08)
                end)
                Btn.MouseButton1Up:Connect(function()
                    tween(Btn, {BackgroundColor3 = Theme.AccentHover}, 0.08)
                end)
                Btn.MouseButton1Click:Connect(cb)
            end

            -- --------------------------------------------------------
            -- DROPDOWN
            -- --------------------------------------------------------
            function Section:CreateDropdown(opts)
                opts = opts or {}
                local options = opts.Options or {}
                local selected = opts.Default or options[1] or "Select..."
                local cb = opts.Callback or function() end
                local isOpen = false

                local wrapper = create("Frame", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 30),
                    ClipsDescendants = false,
                    ZIndex = 5,
                    Parent = ItemContainer
                })

                local Header = create("TextButton", {
                    Text = "",
                    BackgroundColor3 = Theme.SurfaceAlt,
                    Size = UDim2.new(1, 0, 0, 30),
                    ZIndex = 5,
                    Parent = wrapper
                })
                corner(6, Header)
                stroke(Theme.Border, 1, Header)

                create("TextLabel", {
                    Text = (opts.Icon and opts.Icon .. "  " or "") .. (opts.Name or "Dropdown"),
                    Font = Enum.Font.Gotham,
                    TextSize = 11,
                    TextColor3 = Theme.TextMuted,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0, 8, 0, 0),
                    Size = UDim2.new(0.5, 0, 1, 0),
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 6,
                    Parent = Header
                })

                local ValLbl = create("TextLabel", {
                    Text = selected,
                    Font = Enum.Font.GothamBold,
                    TextSize = 11,
                    TextColor3 = Theme.Text,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0.5, 0, 0, 0),
                    Size = UDim2.new(0.5, -26, 1, 0),
                    TextXAlignment = Enum.TextXAlignment.Right,
                    ZIndex = 6,
                    Parent = Header
                })

                local Arrow = create("TextLabel", {
                    Text = "▾",
                    Font = Enum.Font.GothamBold,
                    TextSize = 12,
                    TextColor3 = Theme.TextMuted,
                    BackgroundTransparency = 1,
                    Position = UDim2.new(1, -22, 0, 0),
                    Size = UDim2.new(0, 20, 1, 0),
                    ZIndex = 6,
                    Parent = Header
                })

                local DropFrame = create("Frame", {
                    BackgroundColor3 = Theme.DropdownBg,
                    Position = UDim2.new(0, 0, 1, 4),
                    Size = UDim2.new(1, 0, 0, 0),
                    ClipsDescendants = true,
                    Visible = false,
                    ZIndex = 10,
                    Parent = wrapper
                })
                corner(6, DropFrame)
                stroke(Theme.Border, 1, DropFrame)
                padding(4, 4, 4, 4, DropFrame)
                local dropList = listLayout(DropFrame, 2)

                for _, opt in ipairs(options) do
                    local ItemBtn = create("TextButton", {
                        Text = opt,
                        Font = Enum.Font.Gotham,
                        TextSize = 11,
                        TextColor3 = Theme.Text,
                        BackgroundColor3 = Color3.fromRGB(0,0,0),
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 0, 26),
                        TextXAlignment = Enum.TextXAlignment.Left,
                        ZIndex = 11,
                        Parent = DropFrame
                    })
                    padding(0, 0, 6, 6, ItemBtn)
                    corner(4, ItemBtn)
                    ItemBtn.MouseEnter:Connect(function()
                        tween(ItemBtn, {BackgroundTransparency = 0, BackgroundColor3 = Theme.SurfaceAlt}, 0.1)
                    end)
                    ItemBtn.MouseLeave:Connect(function()
                        tween(ItemBtn, {BackgroundTransparency = 1}, 0.1)
                    end)
                    ItemBtn.MouseButton1Click:Connect(function()
                        selected = opt
                        ValLbl.Text = opt
                        isOpen = false
                        tween(DropFrame, {Size = UDim2.new(1, 0, 0, 0)}, 0.18)
                        task.delay(0.2, function() DropFrame.Visible = false end)
                        Arrow.Text = "▾"
                        cb(opt)
                    end)
                end

                local totalH = #options * 28 + 8
                Header.MouseButton1Click:Connect(function()
                    isOpen = not isOpen
                    Arrow.Text = isOpen and "▴" or "▾"
                    if isOpen then
                        DropFrame.Visible = true
                        DropFrame.Size = UDim2.new(1, 0, 0, 0)
                        tween(DropFrame, {Size = UDim2.new(1, 0, 0, totalH)}, 0.2, Enum.EasingStyle.Back)
                    else
                        tween(DropFrame, {Size = UDim2.new(1, 0, 0, 0)}, 0.18)
                        task.delay(0.2, function() DropFrame.Visible = false end)
                    end
                end)

                local DD = {}
                function DD:Set(v)
                    selected = v
                    ValLbl.Text = v
                    cb(v)
                end
                return DD
            end

            -- --------------------------------------------------------
